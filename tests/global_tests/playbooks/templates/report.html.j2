<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sovereign Cloud Platform Validation Report</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem; color: #1a1a1a; }
    h1 { margin-bottom: 0.25rem; }
    .timestamp { color: #555; margin-bottom: 1.5rem; }
    table { border-collapse: collapse; width: 100%; max-width: 640px; }
    th, td { border: 1px solid #ccc; padding: 0.6rem 0.8rem; text-align: left; }
    th { background: #f4f4f4; }
    .pass { color: #0a7a2f; font-weight: 600; }
    .fail { color: #b00020; font-weight: 600; }
    .overall { margin-top: 1.5rem; font-size: 1.1rem; }
  </style>
</head>
<body>
  <h1>Sovereign Cloud Platform Validation</h1>
  <p class="timestamp">Generated: {{ report_timestamp }}</p>

  <table>
    <thead>
      <tr>
        <th>Component</th>
        <th>Result</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>ArgoCD Applications</td>
        <td class="{{ 'pass' if argocd_check_passed | default(false) else 'fail' }}">
          {{ 'PASS' if argocd_check_passed | default(false) else 'FAIL' }}
        </td>
      </tr>
      <tr>
        <td>Cluster Nodes</td>
        <td class="{{ 'pass' if nodes_check_passed | default(false) else 'fail' }}">
          {{ 'PASS' if nodes_check_passed | default(false) else 'FAIL' }}
        </td>
      </tr>
      <tr>
        <td>Operator Pods</td>
        <td class="{{ 'pass' if operators_check_passed | default(false) else 'fail' }}">
          {{ 'PASS' if operators_check_passed | default(false) else 'FAIL' }}
        </td>
      </tr>
      <tr>
        <td>Platform Services (Vault, Keycloak)</td>
        <td class="{{ 'pass' if services_check_passed | default(false) else 'fail' }}">
          {{ 'PASS' if services_check_passed | default(false) else 'FAIL' }}
        </td>
      </tr>
      <tr>
        <td>Tenancy (Personas, RBAC, Clusters)</td>
        <td class="{{ 'pass' if tenancy_check_passed | default(false) else 'fail' }}">
          {{ 'PASS' if tenancy_check_passed | default(false) else 'FAIL' }}
        </td>
      </tr>
      <tr>
        <td>EDA Event Flow</td>
        <td class="{{ 'pass' if eda_check_passed | default(false) else 'fail' }}">
          {{ 'PASS' if eda_check_passed | default(false) else 'FAIL' }}
        </td>
      </tr>
      <tr>
        <td>Dashboard Routes</td>
        <td class="{{ 'pass' if dashboards_check_passed | default(false) else 'fail' }}">
          {{ 'PASS' if dashboards_check_passed | default(false) else 'FAIL' }}
        </td>
      </tr>
    </tbody>
  </table>

  <p class="overall">
    Overall:
    <span class="{{ 'pass' if overall_passed else 'fail' }}">{{ 'PASS' if overall_passed else 'FAIL' }}</span>
  </p>
</body>
</html>
