{
  "name": "@hybridsovereign/tenant-console-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "OpenShift Console dynamic plugin for Hybrid Sovereign tenant views",
  "main": "dist/plugin-entry.js",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "typecheck": "tsc --noEmit"
  },
  "consolePlugin": {
    "name": "sovereign-tenant-plugin",
    "version": "1.3.4",
    "displayName": "Sovereign Cloud Tenancy",
    "description": "Tenant pages in the Sovereign Cloud perspective",
    "exposedModules": {
      "TenantOverviewPage": "./src/components/TenantOverviewPage.tsx",
      "TenantTeamsPage": "./src/components/TenantTeamsPage.tsx",
      "TenantProjectsPage": "./src/components/TenantProjectsPage.tsx",
      "TenantPlatformsPage": "./src/components/TenantPlatformsPage.tsx",
      "TenantAssignmentsPage": "./src/components/TenantAssignmentsPage.tsx",
      "TenantCloudOSOPage": "./src/components/TenantCloudOSOPage.tsx",
      "TenantCloudAWSPage": "./src/components/TenantCloudAWSPage.tsx",
      "TenantMigrationsPage": "./src/components/TenantMigrationsPage.tsx",
      "TenantVaultsPage": "./src/components/TenantVaultsPage.tsx",
      "TenantVaultKVsPage": "./src/components/TenantVaultKVsPage.tsx",
      "TenantAAPOrgsPage": "./src/components/TenantAAPOrgsPage.tsx",
      "TenantQuayOrgsPage": "./src/components/TenantQuayOrgsPage.tsx",
      "TenantCreatePage": "./src/components/TenantCreatePage.tsx",
      "TenantTeamDetailPage": "./src/components/TenantTeamDetailPage.tsx",
      "TenantProjectDetailPage": "./src/components/TenantProjectDetailPage.tsx",
      "TenantPlatformDetailPage": "./src/components/TenantPlatformDetailPage.tsx",
      "TenantAssignmentDetailPage": "./src/components/TenantAssignmentDetailPage.tsx",
      "TenantCloudOSODetailPage": "./src/components/TenantCloudOSODetailPage.tsx",
      "TenantCloudAWSDetailPage": "./src/components/TenantCloudAWSDetailPage.tsx",
      "TenantMigrationDetailPage": "./src/components/TenantMigrationDetailPage.tsx",
      "TenantVaultDetailPage": "./src/components/TenantVaultDetailPage.tsx",
      "TenantVaultKVDetailPage": "./src/components/TenantVaultKVDetailPage.tsx",
      "TenantAAPOrgDetailPage": "./src/components/TenantAAPOrgDetailPage.tsx",
      "TenantQuayOrgDetailPage": "./src/components/TenantQuayOrgDetailPage.tsx"
    }
  },
  "dependencies": {
    "@hybridsovereign/shared": "*",
    "@openshift-console/dynamic-plugin-sdk": "^1.8.0",
    "@patternfly/react-core": "^5.4.1",
    "@patternfly/react-icons": "^5.4.0",
    "@patternfly/react-table": "^5.4.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk-webpack": "^1.2.0",
    "@types/react": "^17.0.80",
    "@types/react-dom": "^17.0.25",
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  }
}
