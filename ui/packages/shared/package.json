{
  "name": "@hybridsovereign/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types, K8s hooks, and PatternFly theme for Hybrid Sovereign UI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles/openshift.css": "./src/styles/openshift.css"
  },
  "files": ["dist", "src/styles"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.build.json --watch"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@patternfly/react-core": "^5.4.1",
    "@patternfly/react-icons": "^5.4.0",
    "@patternfly/react-styles": "^5.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
